{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Evida Saksrom Structured AI Answer",
  "type": "object",
  "required": [
    "direct_answer",
    "partner_assessment",
    "reasoning_points",
    "uncertainty",
    "next_best_step",
    "suggested_followups",
    "source_ids",
    "answer_quality"
  ],
  "properties": {
    "direct_answer": {
      "type": "string",
      "minLength": 30
    },
    "partner_assessment": {
      "type": "string"
    },
    "reasoning_points": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "uncertainty": {
      "type": "string"
    },
    "next_best_step": {
      "type": "string"
    },
    "suggested_followups": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "maxItems": 4
    },
    "source_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "answer_quality": {
      "type": "object",
      "required": [
        "answered_user_question",
        "question_type",
        "confidence"
      ],
      "properties": {
        "answered_user_question": {
          "type": "boolean"
        },
        "question_type": {
          "type": "string",
          "enum": [
            "case_content",
            "recommendation",
            "process_status",
            "source_question",
            "risk_assessment",
            "timeline",
            "contradiction",
            "evidence",
            "general"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    }
  }
}